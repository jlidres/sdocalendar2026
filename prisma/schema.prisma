generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SchoolEvent {
  id        String   @id @default(cuid())
  start     String   @db.VarChar(10)
  end       String   @db.VarChar(10)
  title     String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([start])
  @@index([end])
  @@unique([start, end, title])
}
